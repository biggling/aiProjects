{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "WebSearch",
      "WebFetch",
      "Bash(npm install *)",
      "Bash(npm run test *)",
      "Bash(npm run lint *)",
      "Bash(npm run typecheck *)",
      "Bash(npm run build *)",
      "Bash(npx *)",
      "Bash(pip install *)",
      "Bash(pip install -r *)",
      "Bash(pytest *)",
      "Bash(python -m pytest *)",
      "Bash(go test *)",
      "Bash(go build *)",
      "Bash(go vet *)",
      "Bash(go run *)",
      "Bash(cargo test *)",
      "Bash(cargo build *)",
      "Bash(cargo clippy *)",
      "Bash(cargo fmt *)",
      "Bash(./mvnw test *)",
      "Bash(./mvnw verify *)",
      "Bash(./gradlew test *)",
      "Bash(alembic upgrade *)",
      "Bash(alembic revision *)",
      "Bash(alembic downgrade *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git fetch *)",
      "Bash(git stash *)",
      "Bash(mkdir *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(echo *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(chmod *)",
      "Bash(cp *)",
      "Bash(mv *)"
    ],
    "deny": [
      "Bash(git push *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -f *)",
      "Bash(rm -rf *)",
      "Bash(rm -r *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(ssh *)",
      "Bash(deploy *)",
      "Bash(railway *)",
      "Bash(fly deploy *)",
      "Bash(vercel *)",
      "Bash(netlify deploy *)",
      "Bash(docker push *)",
      "Bash(kubectl apply *)",
      "Bash(terraform apply *)"
    ]
  }
}
